# ── Database ──
DATABASE_URL=postgresql+asyncpg://mmuser:mmsecret@localhost:5432/marketmind
DATABASE_URL_SYNC=postgresql://mmuser:mmsecret@localhost:5432/marketmind

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── LLM / AI ──
LLM_PROVIDER=openai                     # openai | anthropic | local
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxx
LOCAL_LLM_URL=http://localhost:11434/v1  # For Ollama / local Llama

# ── Embeddings ──
EMBEDDING_PROVIDER=openai               # openai | local
EMBEDDING_MODEL=text-embedding-3-small

# ── Vector DB ──
VECTOR_DB_URL=http://localhost:8080      # Weaviate

# ── News APIs ──
GNEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ET_RSS_URL=https://economictimes.indiatimes.com/rssfeedstopstories.cms

# ── Security ──
API_KEY_ADMIN=changeme-admin-key-12345
SECRET_KEY=changeme-secret-key-67890
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
